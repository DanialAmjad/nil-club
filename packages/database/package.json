{
  "name": "@nil-club/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./queries": {
      "types": "./dist/queries.d.ts",
      "import": "./dist/queries.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:push": "drizzle-kit push:pg",
    "db:seed": "node dist/seed.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.10",
    "@neondatabase/serverless": "^0.9.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "drizzle-kit": "^0.20.14"
  }
}
